{
  "name": "no-mess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --port 4567",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "static-checks": "biome check && tsc --noEmit && tsc -p packages/no-mess-client && tsc --noEmit -p packages/no-mess-cli && tsc --noEmit -p packages/no-mess-mcp && bun run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@clerk/elements": "^0.24.7",
    "@clerk/nextjs": "^6.37.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@no-mess/client": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.357.2",
    "posthog-node": "^5.26.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.6.5",
    "shadcn": "^3.7.0",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
